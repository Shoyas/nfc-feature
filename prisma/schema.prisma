generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Bracelet {
  id        String   @id @default(uuid())
  slug      String   @unique
  nfcCode   String   @unique
  category  String
  createdAt DateTime @default(now())
}

model Verse {
  id       String @id @default(uuid())
  text     String
  category String
}
