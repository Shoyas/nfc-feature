datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Bracelet {
  id        String   @id @default(uuid())
  slug      String   @unique
  category  String
  createdAt DateTime @default(now())
}

model Verse {
  id       String @id @default(uuid())
  text     String
  category String
}
